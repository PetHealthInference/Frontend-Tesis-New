@startuml Sistema_Clinica_Veterinaria
skinparam packageStyle rectangle
skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam class {
  BackgroundColor White
  BorderColor #444444
  ArrowColor #444444
  HeaderBackgroundColor #BBCCEE
}
hide empty methods

title Sistema de Evaluación Clínica Veterinaria\nDiagrama de Clases UML

' ======================================================
' BACKEND :: MODELOS (SQLAlchemy ORM)
' ======================================================
package "Backend :: Modelos" #DDEEFF {

  class Species {
    +id: int <<PK>>
    +name: str[40] <<unique>>
  }

  class Breed {
    +id: int <<PK>>
    +species_id: int <<FK>>
    +name: str[80]
  }

  class Owner {
    +id: int <<PK>>
    +first_name: str[120]
    +last_name: str[120]
    +phone: str[20]
    +email: str[160] <<unique>>
    +address: str[255]
    +department: str[80]
    +province: str[80]
    +district: str[80]
    +ubigeo: str[6]
    +is_active: bool
    +created_at: datetime
  }

  class Patient {
    +id: int <<PK>>
    +owner_id: int <<FK>>
    +name: str[80]
    +species_id: int <<FK>>
    +breed_id: int <<FK, nullable>>
    +sex: str[20]
    +birth_date: date
    +weight: float
    +created_by: int <<FK>>
    +is_active: bool
    +created_at: datetime
  }

  class Role {
    +id: int <<PK>>
    +name: str[40] <<unique>>
    +description: str[255]
  }

  class User {
    +id: int <<PK>>
    +full_name: str[120]
    +email: str[160] <<unique>>
    +password_hash: str[255]
    +role_id: int <<FK>>
    +is_active: bool
  }

  class PasswordResetToken {
    +id: int <<PK>>
    +user_id: int <<FK>>
    +token_hash: str[64] <<unique>>
    +expires_at: datetime
    +used_at: datetime
    +created_at: datetime
  }

  class Disease {
    +id: int <<PK>>
    +name: str[120]
    +species_id: int <<FK>>
    +description: str
    +base_probability: float
    +is_degenerative: bool
    +is_active: bool
  }

  class Symptom {
    +id: int <<PK>>
    +name: str[120]
    +description: str
    +species_id: int <<FK>>
    +is_active: bool
  }

  class ClinicalVariable {
    +id: int <<PK>>
    +key: str[80]
    +name: str[120]
    +data_type: str[30]
    +unit: str[30]
    +normal_min: float
    +normal_max: float
    +species_id: int <<FK, nullable>>
    +is_active: bool
  }

  class ClinicalProbability {
    +id: int <<PK>>
    +disease_id: int <<FK>>
    +symptom_id: int <<FK, nullable>>
    +variable_id: int <<FK, nullable>>
    +expected_value: str[100]
    +probability_given_disease: float
    +general_probability: float
    +is_active: bool
  }

  class EvaluationClinical {
    +id: int <<PK>>
    +patient_id: int <<FK>>
    +veterinarian_id: int <<FK>>
    +reason: str[255]
    +observations: str
    +created_at: datetime
  }

  class EvaluationClinicalFact {
    +id: int <<PK>>
    +evaluation_id: int <<FK>>
    +patient_id: int <<FK>>
    +fact_key: str[100]
    +value: Any <<JSON>>
    +source_type: str[40]
  }

  class ClinicalHistory {
    +id: int <<PK>>
    +patient_id: int <<FK>>
    +evaluation_id: int <<FK, nullable>>
    +event_type: str[60]
    +summary: str
    +created_at: datetime
  }

  class RiskLevel {
    +id: int <<PK>>
    +code: str[20] <<unique>>
    +name: str[40]
    +description: str
    +min_probability: float
    +max_probability: float
    +sort_order: int
    +is_active: bool
  }

  class InferenceRule {
    +id: int <<PK>>
    +code: str[50] <<unique>>
    +name: str[150]
    +disease_id: int <<FK>>
    +risk_level_id: int <<FK>>
    +risk_level: str[20]
    +weight: float
    +priority: int
    +version: int
    +is_active: bool
  }

  class RuleCondition {
    +id: int <<PK>>
    +rule_id: int <<FK>>
    +variable_key: str[100]
    +operator: str[30]
    +expected_value: Any <<JSON>>
    +logical_group: int
  }

  class InferenceResult {
    +id: int <<PK>>
    +evaluation_id: int <<FK>>
    +disease_id: int <<FK>>
    +risk_level_id: int <<FK>>
    +suggested_diagnosis: str[255]
    +risk_level: str[20]
    +score: float
    +probability: float
    +inference_method: str[50]
    +explanation: str
    +created_at: datetime
    --
    +patient_id(): int <<property>>
  }

  class ActivatedRule {
    +id: int <<PK>>
    +result_id: int <<FK>>
    +rule_id: int <<FK>>
    +fulfilled_conditions: Any <<JSON>>
    +justification: str
    +rule_code: str[50]
    +rule_version: int
  }

  class FactDefinition {
    +id: int <<PK>>
    +fact_key: str[100]
    +display_name: str[150]
    +source_type: str[30]
    +data_type: str[30]
    +unit: str[40]
    +allowed_values: object <<JSON>>
    +species_id: int <<FK, nullable>>
    +symptom_id: int <<FK, nullable>>
    +clinical_variable_id: int <<FK, nullable>>
    +is_active: bool
  }

  class KnowledgeSource {
    +id: int <<PK>>
    +title: str[300]
    +citation: str
    +url: str[500]
    +doi: str[200]
    +publication_year: int
    +is_active: bool
  }

  class RuleReference {
    +id: int <<PK>>
    +rule_id: int <<FK>>
    +source_id: int <<FK>>
    +rationale: str
    +locator: str[100]
  }
}

' ======================================================
' BACKEND :: REPOSITORIOS
' ======================================================
package "Backend :: Repositorios" #EEFFDD {

  abstract class "BaseRepository<ModelT>" as BaseRepository {
    #db: Session
    --
    +get(entity_id: int): ModelT | None
    +list(skip: int, limit: int): list[ModelT]
    +add(entity: ModelT): ModelT
    +delete(entity: ModelT): None
  }

  class SpeciesRepository {
    +get_by_name(name: str): Species | None
  }

  class BreedRepository {
    +get_by_name_and_species(name, species_id): Breed | None
    +list_by_species(species_id, skip, limit): list[Breed]
  }

  class OwnerRepository {
    +get_by_email(email: str): Owner | None
    +get_by_id(owner_id: int): Owner | None
    +create(data: dict): Owner
    +update(owner_id: int, data: dict): Owner | None
    +delete(owner_id: int): None
  }

  class PatientRepository {
    +get_with_species(patient_id: int): Patient | None
    +list_with_species(skip, limit): list[Patient]
    +species_exists(species_id: int): bool
    +breed_exists(breed_id: int): bool
    +owner_exists(owner_id: int): bool
  }

  class UserRepository {
    +get_by_email(email: str): User | None
    +list_with_roles(skip, limit): list[User]
    +get_with_role(user_id: int): User | None
    +role_exists(role_id: int): bool
    +save(user: User): User
    +ensure_default_roles(): None
  }

  class EvaluationRepository {
    +get_with_facts(evaluation_id: int): EvaluationClinical | None
    +list_by_patient(patient_id: int): list[EvaluationClinical]
    +list_recent(limit: int): list[EvaluationClinical]
    +create_with_facts(patient_id, veterinarian_id, reason, observations, facts): EvaluationClinical
  }

  class ResultRepository {
    +create_results(evaluation_id, patient_id, results): list[InferenceResult]
    +list_by_evaluation(evaluation_id: int): list[InferenceResult]
    +list_activated_rules(result_id: int): list[ActivatedRule]
  }

  class RuleRepository {
    +get_with_conditions(rule_id: int): InferenceRule | None
    +list_with_conditions(skip, limit): list[InferenceRule]
    +get_active_rules_by_species(species_id: int): list[InferenceRule]
    +get_by_code(code: str): InferenceRule | None
    +create_rule(data, conditions): InferenceRule
    +replace_conditions(rule, conditions): InferenceRule
  }

  class CatalogRepository {
    +list_diseases(): list[Disease]
    +create_disease(disease): Disease
    +list_symptoms(): list[Symptom]
    +list_clinical_variables(): list[ClinicalVariable]
  }

  class ClinicalProbabilityRepository {
    +crear_probabilidad(data: dict): ClinicalProbability
    +listar_probabilidades_por_enfermedad(disease_id): list[ClinicalProbability]
    +buscar_probabilidad_por_evidencia(disease_id, symptom_id, variable_id): ClinicalProbability | None
    +actualizar_probabilidad(entity_id, updates): ClinicalProbability | None
  }

  class HistoryRepository {
    +list_by_patient(patient_id: int): list[ClinicalHistory]
  }

  class PasswordResetTokenRepository {
    +invalidate_active_for_user(user_id, used_at): None
    +create(token: PasswordResetToken): PasswordResetToken
    +get_valid_by_hash(token_hash: str): PasswordResetToken | None
    +mark_used(token, used_at): None
  }
}

' ======================================================
' BACKEND :: SERVICIOS
' ======================================================
