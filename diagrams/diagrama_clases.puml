    --
    +list_users(): list[User]
    +create_user(payload: UserCreate): User
    +update_user(user_id, payload, current_user_id): User
  }

  class OwnerService {
    -repository: OwnerRepository
    --
    +create_owner(schema: OwnerCreate): Owner
    +get_owner(owner_id: int): Owner
    +list_owners(skip, limit): list[Owner]
    +delete_owner(owner_id: int): None
    +update_owner(owner_id, schema): Owner
  }

  class PatientService {
    -repository: PatientRepository
    --
    +list_patients(): list[Patient]
    +get_patient(patient_id: int): Patient
    +create_patient(payload, created_by: int): Patient
    +update_patient(patient_id, payload): Patient
    +delete_patient(patient_id: int): None
  }

  class SpeciesService {
    -repository: SpeciesRepository
    --
    +list_species(skip, limit): list[Species]
    +get_species(species_id: int): Species
    +create_species(payload): Species
    +update_species(species_id, payload): Species
    +delete_species(species_id: int): None
  }

  class BreedService {
    -repository: BreedRepository
    --
    +list_breeds(species_id, skip, limit): list[Breed]
    +get_breed(breed_id: int): Breed
    +create_breed(payload): Breed
    +update_breed(breed_id, payload): Breed
    +delete_breed(breed_id: int): None
  }

  class EvaluationService {
    -evaluation_repository: EvaluationRepository
    -patient_repository: PatientRepository
    --
    +create_evaluation(payload, veterinarian_id): EvaluationClinical
    +get_evaluation(evaluation_id: int): EvaluationClinical
    +list_recent(): list[EvaluationClinical]
    +list_by_patient(patient_id: int): list[EvaluationClinical]
    +list_fact_definitions(species_id): list[FactDefinition]
    +list_fact_definitions_by_source(source_type, species_id): list[FactDefinition]
  }

  class InferenceService {
    -rule_repository: RuleRepository
    -patient_repository: PatientRepository
    -evaluation_repository: EvaluationRepository
    -result_repository: ResultRepository
    -engine: InferenceEngine
    --
    +run_from_payload(patient_id, facts): list[dict]
    +run_and_persist(evaluation_id: int): list[InferenceResult]
    +list_results(evaluation_id: int): list[InferenceResult]
    +list_activated_rules(result_id: int): list[ActivatedRule]
  }

  class BayesService {
    +obtener_evidencias_evaluacion(facts: dict): list[dict]
    +evaluar_reglas(engine, facts, rules): list[dict]
    +calcular_probabilidad_bayes(disease, evidences, clinical_probs): float
    +normalizar_probabilidades(resultados): list[dict]
    +determinar_nivel_riesgo(probabilidad, reglas_activadas): str
    +generar_explicacion_bayes(disease_name, probabilidad, reglas_activadas, evidencias): str
  }

  class RuleService {
    -repository: RuleRepository
    --
    +list_rules(): list[InferenceRule]
    +get_rule(rule_id: int): InferenceRule
    +create_rule(payload: RuleCreate): InferenceRule
    +update_rule(rule_id, payload): InferenceRule
    +update_status(rule_id, payload): InferenceRule
  }

  class CatalogService {
    -repository: CatalogRepository
    --
    +list_diseases(): list[Disease]
    +create_disease(payload): Disease
    +list_symptoms(): list[Symptom]
    +list_clinical_variables(): list[ClinicalVariable]
  }

  class HistoryService {
    -repository: HistoryRepository
    --
    +list_by_patient(patient_id: int): list[ClinicalHistory]
  }
}

' ======================================================
' BACKEND :: MOTOR DE INFERENCIA
' ======================================================
package "Backend :: Inferencia" #FFDDE5 {

  class InferenceEngine {
    -evaluator: ConditionEvaluator
    --
    +evaluate(facts: dict, rules: list): list[dict]
    -_rule_matches(rule, facts, traces): bool
  }

  class ConditionEvaluator {
    +matches(observed, operator, expected): bool
    -_to_float(value): float
    -_range(expected): tuple[float, float]
    -_contains(observed, expected): bool
    -_in(observed, expected): bool
  }

  class ConditionTrace <<dataclass>> {
    +variable_key: str
    +operator: str
    +expected_value: object
    +observed_value: object
    --
    +as_text(): str
  }
}

' ======================================================
' BACKEND :: NUCLEO (excepciones y seguridad)
' ======================================================
package "Backend :: Nucleo" #EEEEEE {

  class AppException {
    +status_code: int
    +detail: str
  }

  class NotFoundError {
    +status_code: int = 404
  }

  class ConflictError {
    +status_code: int = 409
  }

  class UnauthorizedError {
    +status_code: int = 401
  }

  class ForbiddenError {
    +status_code: int = 403
  }
}

' ======================================================
' FRONTEND :: TIPOS (Interfaces TypeScript de dominio)
' ======================================================
package "Frontend :: Tipos" #D0E8FF {

  interface "Species" as FE_Species {
    +id: number
    +name: string
  }

  interface "Breed" as FE_Breed {
    +id: number
    +name: string
    +species_id: number
    +species?: Species
  }

  interface "Owner" as FE_Owner {
    +id: number
    +first_name: string
    +last_name?: string
    +email?: string
    +phone?: string
    +address?: string
    +department?: string
    +province?: string
    +district?: string
    +ubigeo?: string
    +created_at?: string
  }

  interface "Patient" as FE_Patient {
    +id: number
    +name: string
    +species: Species
    +breed?: Breed
    +owner: Owner
    +sex: string
    +birth_date?: string
    +weight?: number
    +created_at: string
  }

  interface "Role" as FE_Role {
    +id: number
    +name: string
    +description?: string
  }

  interface "User" as FE_User {
    +id: number
    +full_name: string
    +email: string
    +is_active: boolean
    +role?: Role
  }

  interface "ClinicalFactIn" as FE_ClinicalFactIn {
    +fact_key: string
    +value: string | number | boolean
    +source_type: "symptom" | "clinical_variable" | "clinical_input"
  }

  interface "ClinicalFactOut" as FE_ClinicalFactOut {
    +id: number
    +fact_key: string
    +value: string | number | boolean
    +source_type: string
  }

  interface "Evaluation" as FE_Evaluation {
    +id: number
    +patient_id: number
    +veterinarian_id?: number
    +reason?: string
    +observations?: string
    +created_at: string
    +result?: string
    +risk_level?: string
    +facts?: ClinicalFactOut[]
  }

  interface "FactDefinition" as FE_FactDefinition {
    +id: number
    +fact_key: string
    +display_name: string
    +source_type: string
    +data_type: string
    +unit?: string
    +allowed_values?: (string|number|boolean)[]
    +species_id?: number
    +is_active: boolean
  }

  interface "PersistedActivatedRule" as FE_PersistedActivatedRule {
    +id: number
    +rule_id: number
    +fulfilled_conditions: unknown
    +justification: string
    +rule_code?: string
    +rule_version?: number
  }

  interface "PersistedInferenceResult" as FE_PersistedInferenceResult {
    +id: number
    +evaluation_id: number
    +patient_id: number
    +disease_id: number
    +risk_level_id: number
    +suggested_diagnosis: string
    +risk_level: string
    +score: number
    +probability?: number
    +inference_method?: string
    +explanation?: string
    +activated_rules: PersistedActivatedRule[]
  }

  interface "Disease" as FE_Disease {
    +id: number
    +name: string
    +species_id: number
    +description?: string
    +is_degenerative: boolean
    +is_active: boolean
  }

  interface "RuleCondition" as FE_RuleCondition {
    +id: number
    +variable_key: string
    +operator: string
    +expected_value: string | number | boolean
    +logical_group?: number
  }

  interface "Rule" as FE_Rule {
    +id: number
    +code: string
    +name: string
    +disease_id: number
    +risk_level_id: number
    +risk_level: string
    +weight: number
    +priority: int
    +version: number
    +is_active: boolean
    +conditions: RuleCondition[]
  }

  interface "RiskLevel" as FE_RiskLevel {
    +id: number
    +code: string
    +name: string
    +description?: string
    +min_probability?: number
    +max_probability?: number
    +sort_order: number
    +is_active: boolean
  }

  interface "PatientHistoryEvaluation" as FE_PatientHistoryEvaluation {
    +evaluation: Evaluation
    +results: PersistedInferenceResult[]
  }

  interface "PatientHistorySummary" as FE_PatientHistorySummary {
    +patient: Patient
    +evaluations: PatientHistoryEvaluation[]
    +events: ClinicalHistoryEvent[]
  }

  interface "AuthState" as FE_AuthState {
    +isAuthenticated: boolean
    +token: string | null
  }

  interface "DashboardData" as FE_DashboardData {
    +recentEvaluations: RecentEvaluation[]
    +recentPatients: RecentPatient[]
  }
}

