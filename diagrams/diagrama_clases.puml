' ======================================================
' RELACIONES :: MODELOS BACKEND
' ======================================================

' Taxonomía
Species "1" --o{ "0..*" Breed       : tiene >
Species "1" --o{ "0..*" Patient     : categoriza >
Species "1" --o{ "0..*" Disease     : afecta >
Species "1" --o{ "0..*" Symptom     : aplica >
Species "1" --o{ "0..*" ClinicalVariable : aplica >

' Propietario / Paciente
Owner   "1" --o{ "1..*" Patient     : posee >
Patient }o-- "1"  Breed             : tiene raza >
Patient }o-- "1"  User              : "creado por" >
Patient "1" --o{ "0..*" EvaluationClinical : tiene >
Patient "1" --o{ "0..*" ClinicalHistory    : registra >

' Usuario / Rol
Role "1" --o{ "0..*" User           : otorga >
User "1" --o{ "0..*" EvaluationClinical : realiza >
User "1" --o| "0..*" PasswordResetToken : posee >

' Evaluación
EvaluationClinical "1" *-- "1..*" EvaluationClinicalFact : contiene >
EvaluationClinical "1" --o{ "0..*" InferenceResult        : genera >
EvaluationClinical "1" --o| "0..*" ClinicalHistory        : origina >

' Resultados de inferencia
InferenceResult "1" *-- "0..*" ActivatedRule  : registra >
InferenceResult }o-- "1" Disease              : diagnostica >
InferenceResult }o-- "1" RiskLevel            : clasifica >
ActivatedRule   }o-- "1" InferenceRule        : referencia >

' Base de conocimiento
Disease "1" --o{ "0..*" InferenceRule        : define >
Disease "1" --o{ "0..*" ClinicalProbability  : estima >
RiskLevel "1" --o{ "0..*" InferenceRule      : asigna >
InferenceRule "1" *-- "1..*" RuleCondition   : compone >
InferenceRule "1" --o{ "0..*" RuleReference  : respalda >
KnowledgeSource "1" --o{ "0..*" RuleReference : citada >

' Probabilidades clínicas
ClinicalProbability }o-- "0..1" Symptom          : evalúa >
